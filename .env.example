# ============================================
# 🌳 QwenTree — Configuration
# ============================================

# --- API Mode ---
# "qwen" for Qwen Cloud (submission) | "fallback" for development
API_MODE=fallback

# --- Qwen Cloud API (for submission) ---
QWEN_API_KEY=sk-your-qwen-api-key
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- Models ---
QWEN_MODEL=qwen3.7-plus
QWEN_MODEL_MAX=qwen3.7-max
QWEN_CODER_MODEL=qwen-coder-plus
QWEN_VL_MODEL=qwen-vl-max
QWEN_VL_PLUS=qwen-vl-plus
QWEN_AUDIO_MODEL=qwen-audio
QWEN_TTS_MODEL=cosyvoice-01
QWEN_IMAGE_MODEL=wan
QWEN_VIDEO_MODEL=wan-video
QWEN_EMBEDDING_MODEL=text-embedding-v3

# --- Fallback APIs (for development/testing) ---
FALLBACK_API_KEY=your-fallback-key
FALLBACK_BASE_URL=https://api.openai.com/v1
FALLBACK_MODEL=gpt-4o

# --- Databases ---
CHROMA_HOST=localhost
CHROMA_PORT=8001
POSTGRES_DSN=postgresql://qwentree:qwentree_secret@localhost:5433/qwentree
REDIS_URL=redis://localhost:6380/0

# --- Integrations ---
SHIVA_API_URL=http://localhost:8001
SHIVA_API_KEY=
N8N_URL=http://localhost:5678
N8N_API_KEY=

# --- Memory Tuning ---
MENTAL_MODELS_TOP_K=5
MENTAL_MODELS_SCORE_THRESHOLD=0.7
OBSERVATIONS_RECENCY_DAYS=30
RAW_FACTS_TTL=3600
